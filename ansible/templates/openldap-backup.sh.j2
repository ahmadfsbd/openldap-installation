#!/bin/sh
set -eu

umask 077

backup_root="{{ ldap_backup_dir }}"
timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
backup_dir="${backup_root}/${timestamp}"

mkdir -p "${backup_dir}"

slapcat -n 0 -l "${backup_dir}/config.ldif"
slapcat -n 1 -l "${backup_dir}/data.ldif"

find "${backup_root}" -mindepth 1 -maxdepth 1 -type d -mtime +{{ ldap_backup_retention_days }} -exec rm -rf {} \;

echo "OpenLDAP backup written to ${backup_dir}"
